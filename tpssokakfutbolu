    lb.BackgroundTransparency = 1
    lb.TextColor3 = Color3.fromRGB(249,217,97)
    lb.Text = label or part.Name
    lb.Font = Enum.Font.GothamBlack
    lb.TextScaled = true
end

RunService.RenderStepped:Connect(function()
    if not TPSMENU.Enabled or not AnaFrame or not AnaFrame.Parent then return end

    local hum = getHum()
    if hum then
        hum.WalkSpeed = hileVars.walkspeed or 16
        hum.JumpPower = hileVars.jumppower or 50
    end

    if hileVars.sonsuzstamina then
        for _,v in pairs(Workspace:GetDescendants()) do
            if v:IsA("NumberValue") and v.Name:lower():find("stamina") then v.Value = 13000 end
        end
    end

    if hileVars.noclip or hileVars.duvargec then
        local char = getChar()
        if char then
            for _,v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end

    if hileVars.antikick and setreadonly and getrawmetatable then
        local mt = getrawmetatable(game)
        if mt and not mt.__YineMenuFix__ then
            setreadonly(mt, false)
            mt.__YineMenuFix__ = true
            local old = mt.__namecall
            mt.__namecall = function(self, ...)
                local method = getnamecallmethod and getnamecallmethod()
                if method == "Kick" then return end
                return old(self, ...)
            end
            setreadonly(mt, true)
        end
    end

    if hileVars.magnettop and getBall() and getRoot() then
        local ball = getBall()
        if ball and ball:IsA("BasePart") then
            ball.CFrame = getRoot().CFrame + Vector3.new(0,2,0)
        end
    end

    if hileVars.topbuyut and getBall() then
        getBall().Size = Vector3.new(10,10,10)
    end

    if hileVars.toplumesp and getBall() then
        makeESP(getBall(),"TOP")
    end

    if hileVars.oyuncuesp then
        for _,p in pairs(Players:GetPlayers()) do
            if p ~= localPlayer and p.Character and p.Character:FindFirstChild("Head") then
                makeESP(p.Character.Head, p.DisplayName or p.Name)
            end
        end
    end

    if hileVars.rainbowui and AnaFrame then
        local hsv = tick()%1
        AnaFrame.BackgroundColor3 = Color3.fromHSV(hsv,0.6,0.35)
    else
        AnaFrame.BackgroundColor3 = Color3.fromRGB(30,34,50)
    end

    if hileVars.gravity then
        Workspace.Gravity = 30
    else
        Workspace.Gravity = 196.2
    end

    if hileVars.godmode and getHum() then
        local h = getHum()
        h.Health = h.MaxHealth
        h.BreakJointsOnDeath = false
        h.PlatformStand = false
        h.Sit = false
    end

    if hileVars.fakeLag then
        RunService:Set3dRenderingEnabled(false)
        wait(0.17)
        RunService:Set3dRenderingEnabled(true)
    end

    if hileVars.infjump and not _G.YINEINFJCONN then
        _G.YINEINFJCONN = true
        UserInputService.JumpRequest:Connect(function()
            local h = getHum()
            if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
        end)
    end

    if hileVars.supervision and Lighting then
        Lighting.FogEnd = 9e5
        Lighting.Brightness = 12
        Lighting.ExposureCompensation = 2.5
    end

    if hileVars.fov and workspace.CurrentCamera then
        pcall(function()
            workspace.CurrentCamera.FieldOfView = hileVars.fov
        end)
    end

    if hileVars.camzoom and workspace.CurrentCamera then
        workspace.CurrentCamera.CameraSubject = getHum()
        workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
        workspace.CurrentCamera.FieldOfView = hileVars.fov
    end

    if hileVars.otoblok then
        if getRoot() and getBall() then
            local char = getChar()
            if not char then return end
            local dist = (getBall().Position - getRoot().Position).Magnitude
            if dist < 12 then
                for _,v in pairs(char:GetChildren()) do
                    if v:IsA("Tool") and v.Name:lower():find("blok") then v:Activate() end
                end
            end
        end
    end

    if hileVars.kutuhin then
        for _,v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") and v.Name:lower():find("kutupick") then
                if getRoot() then v.CFrame = getRoot().CFrame + Vector3.new(2.5,0,0) end
            end
        end
    end

    if hileVars.bossmod then
        for _,v in pairs(Players:GetPlayers()) do
            if v ~= localPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                v.Character.HumanoidRootPart.CanCollide = false
            end
        end
    end

    if hileVars.tpshack and getHum() then
        getHum().WalkSpeed = math.random(18, 56)
    end

    if hileVars.autotakim and ReplicatedStorage:FindFirstChild("TakimDegistir") then
        local rem = ReplicatedStorage:FindFirstChild("TakimDegistir")
        if rem:IsA("RemoteEvent") then
            rem:FireServer("AutoTakim")
        end
    end

    if hileVars.autoskill then
        if getChar() then
            for _,tool in pairs(getChar():GetChildren()) do
                if tool:IsA("Tool") and tool.Name:lower():find("pas") then
                    tool:Activate()
                end
            end
        end
    end

    if hileVars.powerkick and getChar() then
        for _,tool in pairs(getChar():GetChildren()) do
            if tool:IsA("Tool") and tool.Name:lower():find("kick") then
                tool:Activate()
            end
        end
    end

    if hileVars.topdeposu and getBall() and getRoot() then
        getBall().CFrame = getRoot().CFrame + Vector3.new(0,1,0)
    end

    if hileVars.otoGol and getBall() and getRoot() then
        local kale = Workspace:FindFirstChild("GoalB")
        if kale and kale:IsA("BasePart") then
            getBall().CFrame = kale.CFrame + Vector3.new(0,2,0)
        end
    end

    if hileVars.infpass and getgc and debug then
        for _,f in ipairs(getgc(true)) do
            -- kodun devamı aynı
