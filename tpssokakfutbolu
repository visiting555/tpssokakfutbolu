local function makeESP(part,label)
    if part:FindFirstChild("ESPUI") then return end
    local bill = Instance.new("BillboardGui", part)
    bill.Name = "ESPUI"
    bill.Size = UDim2.new(0,160,0,36)
    bill.AlwaysOnTop = true
    bill.StudsOffset = Vector3.new(0,3,0)
    local lb = Instance.new("TextLabel",bill)
    lb.Size = UDim2.new(1,0,1,0)
    lb.BackgroundTransparency = 1
    lb.TextColor3 = Color3.fromRGB(249,217,97)
    lb.Text = label or part.Name
    lb.Font = Enum.Font.GothamBlack
    lb.TextScaled = true
end

