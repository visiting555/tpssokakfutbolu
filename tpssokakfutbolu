local function getSafeParent()
    local playerGui = localPlayer and localPlayer:FindFirstChildOfClass("PlayerGui")
    if playerGui then
        return playerGui
    elseif pcall(function() return CoreGui end) then
        return CoreGui
    else
        return nil
    end
end

