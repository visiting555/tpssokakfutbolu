function teamEsp()
    for _,p in pairs(Players:GetPlayers()) do
        if p~=getP() and p.Team==getP().Team then
            local c=p.Character
            if c and c:FindFirstChild("Head") and not c.Head:FindFirstChild("ESP") then
                local b=Instance.new("BillboardGui",c.Head)
                b.Name="ESP"
                b.Size=UDim2.new(0,80,0,16)
                b.StudsOffset=Vector3.new(0,2,0)
                local t=Instance.new("TextLabel",b)
                t.Size=UDim2.new(1,0,1,0)
                t.BackgroundTransparency=1
                t.Text=p.Name
                t.TextColor3=Color3.fromRGB(25,255,50)
            end
        end
    end
end

function autoGoal()
    local c=getChar()
    if not c then return end
    local g=nil
    for _,v in pairs(workspace:GetChildren()) do
        if v.Name:lower():find("goal") or v.Name:lower():find("kale") then
            g=v
        end
    end
    if g then
        c:SetPrimaryPartCFrame(g.CFrame + Vector3.new(0,0,3))
    end
end

function autoDef()
    local c=getChar()
    if not c then return end
    for _,v in pairs(workspace:GetChildren()) do
        if v.Name:lower():find("defend") then
            c:SetPrimaryPartCFrame(v.CFrame+Vector3.new(0,0,1))
        end
    end
end

function autoGoalie()
    local c=getChar()
    if not c then return end
