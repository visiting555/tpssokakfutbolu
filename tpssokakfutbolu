local function MakeToggle(tab, row, label, props, key)
    local btn = Instance.new("TextButton")
    btn.Name = "Toggle_"..key
    btn.Size = UDim2.new(0.47,0,0,34)
    btn.Position = UDim2.new((row%2==1 and 0.025 or 0.51),0,0,math.floor((row-1)/2)*39+7)
    btn.BackgroundColor3 = props[key] and Color3.fromRGB(120,255,99) or Color3.fromRGB(46,46,70)
    btn.TextColor3 = props[key] and Color3.fromRGB(41,39,39) or Color3.fromRGB(192,255,200)
    btn.Font = Enum.Font.GothamBlack
    btn.TextSize = 15
    btn.Text = ("%s [%s]"):format(label,props[key] and "AÇIK" or "KAPALI")
    btn.Parent = TabFrames[tab]
    btn.MouseButton1Click:Connect(function()
        props[key] = not props[key]
        btn.Text = ("%s [%s]"):format(label,props[key] and "AÇIK" or "KAPALI")
        btn.BackgroundColor3 = props[key] and Color3.fromRGB(120,255,99) or Color3.fromRGB(46,46,70)
        btn.TextColor3 = props[key] and Color3.fromRGB(41,39,39) or Color3.fromRGB(192,255,200)
    end)
end
local function MakeSlider(tab, row, text, min, max, prop, key)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.7,0,0,16)
    label.Position = UDim2.new(0.038,0,0,((row-1)*38+2))
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamBold
    label.TextColor3 = Color3.fromRGB(235,240,170)
    label.TextSize = 12
    label.Text = ("%s : %s"):format(text,prop[key])
    label.Parent = TabFrames[tab]

    local slider = Instance.new("Frame")
    slider.Position=UDim2.new(0.03,0,0,((row-1)*38+18))
    slider.Size=UDim2.new(0.85,0,0,14)
    slider.BackgroundColor3=Color3.fromRGB(95,132,198)
    slider.BorderSizePixel=0
    slider.Parent=TabFrames[tab]

    local slideBar = Instance.new("Frame")
    slideBar.Size=UDim2.new((prop[key]-min)/(max-min),0,1,0)
    slideBar.Position=UDim2.new(0,0,0,0)
    slideBar.BackgroundColor3=Color3.fromRGB(234,227,57)
    slideBar.BorderSizePixel=0
    slideBar.Parent=slider

    local drag = false
    slider.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end
    end)
    slider.InputEnded:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
    end)
    slider.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and drag then
            local mx = input.Position.X - slider.AbsolutePosition.X
            local pct = math.clamp(mx/slider.AbsoluteSize.X,0,1)
            slideBar.Size=UDim2.new(pct,0,1,0)
            local val=math.floor(min + pct*(max-min))
            label.Text=("%s : %s"):format(text,val)
            prop[key]=val
        end
    end)
end
