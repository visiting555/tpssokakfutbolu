    return w:FindFirstChild("Ball") or (w:FindFirstChild("Balls") and w.Balls:FindFirstChildWhichIsA("BasePart")) or nil
end

local heartbeat = RunService.RenderStepped
local function haxLoop()
    if not menuOpen then return end

    if hiles.walkspeed and getC() and getC():FindFirstChildOfClass("Humanoid") then
        getC():FindFirstChildOfClass("Humanoid").WalkSpeed = hiles.camzoom or 100
    elseif getC() and getC():FindFirstChildOfClass("Humanoid") then
        getC():FindFirstChildOfClass("Humanoid").WalkSpeed = 16
    end

    if hiles.jumppower and getC() and getC():FindFirstChildOfClass("Humanoid") then
        getC():FindFirstChildOfClass("Humanoid").JumpPower = 180
    elseif getC() and getC():FindFirstChildOfClass("Humanoid") then
        getC():FindFirstChildOfClass("Humanoid").JumpPower = 60
    end

    if hiles.infstamina then
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("NumberValue") and v.Name:lower():find("stamina") then
                v.Value = 99999
            end
        end
    end

    if hiles.catchball and getBall() and getC() then
        getC():MoveTo(getBall().Position + Vector3.new(0,2,0))
    end

    if hiles.wallpass and getC() then
        for _,v in pairs(getC():GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end

    if hiles.antikick and setreadonly and getrawmetatable then
        setreadonly(getrawmetatable(game), false)
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        mt.__namecall = function(self, ...)
            if getnamecallmethod and getnamecallmethod() == "Kick" then return end
            return old(self, ...)
        end
        setreadonly(mt, true)
    end

    if hiles.magnet and getBall() and getC() then
        getBall().CFrame = getC().HumanoidRootPart.CFrame + Vector3.new(0,2,0)
    end

    if hiles.ballsize and getBall() then
        getBall().Size = Vector3.new(8,8,8)
        hiles.ballsize=false
    end

    if hiles.noclip and getC() then
        for _,v in pairs(getC():GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end

    if hiles.espball and getBall() then
        if not getBall():FindFirstChild("ESPUI") then
            local bb = Instance.new("BillboardGui", getBall())
            bb.Name = "ESPUI"
            bb.Size = UDim2.new(0,135,0,40)
            bb.StudsOffset = Vector3.new(0,3,0)
            local t = Instance.new("TextLabel", bb)
            t.Size = UDim2.new(1,0,1,0)
            t.BackgroundTransparency = 1
            t.Text = "TOP ŞU ANDA BURADA"
            t.TextColor3 = Color3.fromRGB(255,255,80)
            t.Font = Enum.Font.GothamBlack
            t.TextScaled = true
        end
    end

    if hiles.espplayer then
        for _,p in pairs(Players:GetPlayers()) do
            if p ~= localPlayer and p.Character and p.Character:FindFirstChild("Head") then
                local h = p.Character.Head
                if not h:FindFirstChild("ESPTag") then
                    local b = Instance.new("BillboardGui", h)
                    b.Name = "ESPTag"
                    b.Size = UDim2.new(0,90,0,18)
                    b.StudsOffset = Vector3.new(0,2.1,0)
                    local tx = Instance.new("TextLabel", b)
                    tx.Size = UDim2.new(1,0,1,0)
                    tx.BackgroundTransparency = 1
                    tx.Text = p.DisplayName or p.Name
                    tx.TextColor3 = Color3.fromRGB(122,255,128)
                    tx.Font = Enum.Font.GothamBold
                    tx.TextScaled = true
                end
            end
        end
    end

    if hiles.rainbowui and menu then
        local h = tick()%1
        menu.BackgroundColor3 = Color3.fromHSV(h,0.46,0.33)
    end

    if hiles.infpass and getgc then
        for _,func in pairs(getgc(true)) do
            if type(func)=="function" and islclosure(func) and debug.getinfo(func).name:lower():find("cooldown") then
                for i=1,debug.getinfo(func).nups do
                    local uv = debug.getupvalue(func,i)
                    if type(uv)=="number" then debug.setupvalue(func,i,0) end
                end
            end
        end
    end

    if hiles.autoFarm and getBall() and getC() then
        getC():MoveTo(getBall().Position)
        wait(.12)
        for _,v in pairs(workspace:GetChildren()) do
            if v.Name:lower():find("goal") or v.Name:lower():find("kale") then
                getC():MoveTo(v.Position + Vector3.new(0,2,0))
            end
        end
    end

    if hiles.balltp and getBall() and getC() then
        getC():MoveTo(getBall().Position + Vector3.new(0,1.5,0))
        hiles.balltp=false
    end

    if hiles.godmode and getC() then
        for _,v in pairs(getC():GetChildren()) do
            if v:IsA("Humanoid") then v.MaxHealth = 1e7 v.Health = 1e7 end
        end
    end

    if hiles.hugehitbox and getC() then
        for _,v in pairs(getC():GetDescendants()) do
            if v:IsA("BasePart") then
                v.Size = v.Size + Vector3.new(5,5,5)
            end
        end
    end

    if hiles.antistun and getC() and getC():FindFirstChildOfClass("Humanoid") then
        getC():FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Physics)
        getC():FindFirstChildOfClass("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.Physics, false)
    end

    if hiles.blockkick and setreadonly and getrawmetatable then
        setreadonly(getrawmetatable(game), false)
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        mt.__namecall = function(self, ...)
            if getnamecallmethod and getnamecallmethod() == "Kick" then return end
            return old(self, ...)
        end
        setreadonly(mt, true)
    end

    if hiles.autoGoal and getBall() and getC() then
        local closestGoal = nil
        local minDist = math.huge
        for _,v in pairs(workspace:GetChildren()) do
            if v:IsA("BasePart") and (v.Name:lower():find("goal") or v.Name:lower():find("kale")) then
                local dist = (getBall().Position-v.Position).Magnitude
                if dist < minDist then minDist = dist closestGoal = v end
            end
        end
        if closestGoal then
            getC():MoveTo(getBall().Position)
            wait(.18)
            getC():MoveTo(closestGoal.Position + Vector3.new(0,2,0))
        end
    end

    if hiles.freezeOthers then
        for _,p in pairs(Players:GetPlayers()) do
            if p ~= localPlayer and p.Character and p.Character:FindFirstChildOfClass("Humanoid") then
                p.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = 0
            end
        end
    end

    if hiles.fakeLag and getC() then
        RunService.Heartbeat:Wait()
        wait(math.random()*.25+.1)
    end

    if hiles.fakePing then
        wait(math.random() * .15)
    end

    if hiles.gravity then
        workspace.Gravity = 0
    else
        workspace.Gravity = 196.2
    end

    for k,v in pairs(hiles.extraVars) do
        if v then
            -- Burada extralar örnek davranış gösterebilir
        end
    end

end

heartbeat:Connect(haxLoop)

