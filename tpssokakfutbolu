local function performCheats()
    if not menuOpen then return end
    local c = getC()
    local h = c and c:FindFirstChildOfClass("Humanoid")
    if hiles.walkspeed and h then
        h.WalkSpeed = hiles.camzoom or 28
    elseif h then
        h.WalkSpeed = 16
    end

    if hiles.jumppower and h then
        h.JumpPower = 180
    elseif h then
        h.JumpPower = 60
    end

    if hiles.infstamina then
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("NumberValue") and v.Name:lower():find("stamina") then
                v.Value = 99999
            end
        end
    end

    if hiles.catchball and getBall() and c then
        c:MoveTo(getBall().Position + Vector3.new(0,2,0))
    end

    if hiles.wallpass and c then
        for _,v in pairs(c:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end

    if hiles.antikick and setreadonly and getrawmetatable then
        setreadonly(getrawmetatable(game), false)
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        mt.__namecall = function(self, ...)
            if getnamecallmethod and getnamecallmethod() == "Kick" then return end
            return old(self, ...)
        end
        setreadonly(mt, true)
    end

    if hiles.magnet and getBall() and c then
        getBall().CFrame = c.HumanoidRootPart.CFrame + Vector3.new(0,2,0)
    end

    if hiles.ballsize and getBall() then
        getBall().Size = Vector3.new(8,8,8)
        hiles.ballsize = false
    end

    if hiles.noclip and c then
        for _,v in pairs(c:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end

    if hiles.espball and getBall() then
        if not getBall():FindFirstChild("ESPUI") then
            local bb = Instance.new("BillboardGui", getBall())
            bb.Name = "ESPUI"
            bb.Size = UDim2.new(0,135,0,40)
            bb.StudsOffset = Vector3.new(0,3,0)
            bb.AlwaysOnTop = true
            local t = Instance.new("TextLabel", bb)
            t.Size = UDim2.new(1,0,1,0)
            t.BackgroundTransparency = 1
            t.Text = "TOP BURADA"
            t.TextColor3 = Color3.fromRGB(255,255,70)
            t.Font = Enum.Font.GothamBlack
            t.TextScaled = true
        end
    end

    if hiles.espplayer then
        for _,p in pairs(Players:GetPlayers()) do
            if p ~= localPlayer and p.Character and p.Character:FindFirstChild("Head") then
                local h = p.Character.Head
                if not h:FindFirstChild("ESPTag") then
                    local b = Instance.new("BillboardGui", h)
                    b.Name = "ESPTag"
                    b.Size = UDim2.new(0,90,0,18)
                    b.StudsOffset = Vector3.new(0,2,0)
                    b.AlwaysOnTop = true
                    local tx = Instance.new("TextLabel", b)
                    tx.Size = UDim2.new(1,0,1,0)
                    tx.BackgroundTransparency = 1
                    tx.Text = p.DisplayName or p.Name
                    tx.TextColor3 = Color3.fromRGB(110,255,162)
                    tx.Font = Enum.Font.GothamBold
                    tx.TextScaled = true
                end
            end
        end
    end

    if hiles.rainbowui and menu then
        local h = tick()%1
        menu.BackgroundColor3 = Color3.fromHSV(h,0.36,0.34)
    end

    if hiles.infpass and getgc then
        for _,func in pairs(getgc(true)) do
            if type(func)=="function" and islclosure(func) and debug.getinfo(func).name:lower():find("cooldown") then
                for i=1,debug.getinfo(func).nups do
                    local uv = debug.getupvalue(func,i)
                    if type(uv)=="number" then debug.setupvalue(func,i,0) end
                end
            end
        end
    end

    if hiles.autoFarm and getBall() and c then
        c:MoveTo(getBall().Position)
        wait(.13)
        for _,v in pairs(workspace:GetChildren()) do
            if v.Name:lower():find("goal") or v.Name:lower():find("kale") then
                c:MoveTo(v.Position + Vector3.new(0,2,0))
            end
        end
    end

    if hiles.balltp and getBall() and c then
        c:MoveTo(getBall().Position + Vector3.new(0,.8,0))
        hiles.balltp=false
    end

    if hiles.godmode and c then
        for _,v in pairs(c:GetChildren()) do
            if v:IsA("Humanoid") then v.MaxHealth=9999999 v.Health=9999999 end
        end
    end

    if hiles.hugehitbox and c then
        for _,v in pairs(c:GetDescendants()) do
            if v:IsA("BasePart") then
                v.Size = v.Size + Vector3.new(6,6,6)
            end
        end
    end

    if hiles.antistun and c and c:FindFirstChildOfClass("Humanoid") then
        c:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Physics)
        c:FindFirstChildOfClass("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.Physics, false)
    end

    if hiles.blockkick and setreadonly and getrawmetatable then
        setreadonly(getrawmetatable(game), false)
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        mt.__namecall = function(self, ...)
            if getnamecallmethod and getnamecallmethod() == "Kick" then return end
            return old(self, ...)
        end
        setreadonly(mt, true)
    end

    if hiles.autoGoal and getBall() and c then
        local closestGoal = nil
        local minDist = math.huge
        for _,v in pairs(workspace:GetChildren()) do
            if v:IsA("BasePart") and (v.Name:lower():find("goal") or v.Name:lower():find("kale")) then
                local dist = (getBall().Position-v.Position).Magnitude
                if dist < minDist then minDist = dist closestGoal = v end
            end
        end
        if closestGoal then
            c:MoveTo(getBall().Position)
            wait(.13)
            c:MoveTo(closestGoal.Position + Vector3.new(0,2,0))
        end
    end

    if hiles.freezeOthers then
        for _,p in pairs(Players:GetPlayers()) do
            if p ~= localPlayer and p.Character and p.Character:FindFirstChildOfClass("Humanoid") then
                p.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = 0
            end
        end
    end

    if hiles.fakeLag and c then
        RunService.Heartbeat:Wait()
        wait(math.random()*.18+.08)
    end

    if hiles.fakePing then
        wait(math.random() * .13)
    end

    if hiles.gravity then
        workspace.Gravity = 0
    else
        workspace.Gravity = 196.2
    end

    if hiles.spawnBall then
        local template = ReplicatedStorage:FindFirstChild("Ball") or workspace:FindFirstChild("Ball")
        if template then
            local b = template:Clone()
            b.Parent = workspace
            b.Position = c and c.HumanoidRootPart and (c.HumanoidRootPart.Position+Vector3.new(0,7,0)) or Vector3.new(0,8,0)
        end
        hiles.spawnBall = false
    end

    -- Extra, sistemik işlemler ve örnekler
    for k,v in pairs(hiles.extraVars) do
        if v then
            -- örnek ekstra; birşeyler yapılabilir, placeholder
        end
    end
end

