local function createToggle(tab,y,text,ref, key)
    local toggle = Instance.new("TextButton", tab)
    toggle.Name = "Toggle_"..tostring(key)
    toggle.Size = UDim2.new(0.47,0,0,36)
    toggle.Position = UDim2.new((y%2 == 1) and 0.03 or 0.51,0,0,math.floor((y-1)/2)*41+7)
    toggle.BackgroundColor3 = Color3.fromRGB(52,54,73)
    toggle.BorderSizePixel = 0
    toggle.TextColor3 = ref[key] and Color3.fromRGB(90,255,80) or Color3.fromRGB(170,180,210)
    toggle.Font = Enum.Font.GothamBold
    toggle.TextSize = 15
    toggle.Text = ("%s [%s]"):format(text,ref[key] and "AÇIK" or "KAPALI")
    toggle.AutoButtonColor = true
    toggle.MouseButton1Click:Connect(function()
        ref[key] = not ref[key]
        toggle.Text = ("%s [%s]"):format(text,ref[key] and "AÇIK" or "KAPALI")
        toggle.TextColor3 = ref[key] and Color3.fromRGB(90,255,80) or Color3.fromRGB(170,180,210)
        if key=="rainbowui" and ref[key] then
            spawn(function()
                while ref[key] and menu and menu.Parent do
                    for h=0,1,.017 do
                        menu.BackgroundColor3 = Color3.fromHSV(h,.41,.37)
                        wait(.018)
                        if not ref[key] then break end
                    end
                end
                menu.BackgroundColor3 = Color3.fromRGB(35,38,48)
            end)
        end
    end)
end

