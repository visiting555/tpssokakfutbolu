local function createToggle(tab, row, text, ref, key)
    local tgl = Instance.new("TextButton", tab)
    tgl.Name = "Tgl_"..(key or #tab:GetChildren())
    tgl.Size = UDim2.new(0.48,0,0,34)
    tgl.Position = UDim2.new((row%2==1) and 0.02 or 0.50, 0, 0, math.floor((row-1)/2)*37+8)
    tgl.BackgroundColor3 = Color3.fromRGB(52,54,73)
    tgl.BorderSizePixel = 0
    tgl.TextColor3 = ref[key] and Color3.fromRGB(80,255,98) or Color3.fromRGB(195,195,240)
    tgl.Font = Enum.Font.GothamBold
    tgl.TextSize = 15
    tgl.Text = ("%s [%s]"):format(text, ref[key] and "AÇIK" or "KAPALI")
    tgl.AutoButtonColor = true
    tgl.MouseButton1Click:Connect(function()
        ref[key] = not ref[key]
        tgl.Text = ("%s [%s]"):format(text, ref[key] and "AÇIK" or "KAPALI")
        tgl.TextColor3 = ref[key] and Color3.fromRGB(80,255,98) or Color3.fromRGB(195,195,240)
        if key == "rainbowui" and ref[key] then
            spawn(function()
                while ref[key] and menu and menu.Parent do
                    for h=0,1,0.009 do
                        menu.BackgroundColor3 = Color3.fromHSV(h,0.39,0.33)
                        wait(0.012)
                        if not ref[key] then break end
                    end
                end
                menu.BackgroundColor3 = Color3.fromRGB(33,34,46)
            end)
        end
    end)
end

