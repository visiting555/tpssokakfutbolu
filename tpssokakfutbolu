local function createSlider(tab,y,text,min,max,ref,key)
    local label = Instance.new("TextLabel",tab)
    label.Size = UDim2.new(0.94,0,0,28)
    label.Position = UDim2.new(0.03,0,0,(y-1)*44+6)
    label.Text = text..": "..tostring(ref[key])
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.BorderSizePixel = 0
    label.TextColor3 = Color3.fromRGB(220,220,120)
    label.BackgroundTransparency = 1

    local sliderBar = Instance.new("Frame",tab)
    sliderBar.Size = UDim2.new(0.74,0,0,9)
    sliderBar.Position = UDim2.new(0.03,0,0,(y-1)*44+33)
    sliderBar.BackgroundColor3 = Color3.fromRGB(120,120,140)
    sliderBar.BorderSizePixel = 0

    local handle = Instance.new("Frame",sliderBar)
    handle.Size = UDim2.new(.08,0,1,0)
    handle.Position = UDim2.new((ref[key]-min)/(max-min),0,0,0)
    handle.BackgroundColor3 = Color3.fromRGB(255,226,51)
    handle.BorderSizePixel = 0

    local dragging = false
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)
    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    sliderBar.InputChanged:Connect(function(input)
        if dragging and input.UserInputType==Enum.UserInputType.MouseMovement then
            local mx = input.Position.X-sliderBar.AbsolutePosition.X
            local ratio = math.clamp(mx/sliderBar.AbsoluteSize.X,0,1)
            handle.Position = UDim2.new(ratio,0,0,0)
            local val = math.floor(min+ratio*(max-min))
            label.Text = text..": "..val
            ref[key]=val
        end
    end)
end

