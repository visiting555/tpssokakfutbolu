function getBall()
    local w=workspace
    return w:FindFirstChild("Ball") or (w:FindFirstChild("Balls") and w.Balls:FindFirstChildWhichIsA("BasePart")) or nil
end

function setWalkSpeed(n)
    local c = getChar()
    if c and c:FindFirstChildOfClass("Humanoid") then
        c:FindFirstChildOfClass("Humanoid").WalkSpeed = n
    end
end

function setJumpPower(n)
    local c = getChar()
    if c and c:FindFirstChildOfClass("Humanoid") then
        c:FindFirstChildOfClass("Humanoid").JumpPower = n
    end
end

function infStamina()
    for _,v in pairs(workspace:GetDescendants()) do
        if v.Name:lower():find("stamina") and v:IsA("NumberValue") then
            v.Value=99999
        end
    end
end

function noCooldown()
    if not getgc then return end
    for _,v in pairs(getgc(true)) do
        if typeof(v)=="function" and islclosure(v) and debug.getinfo(v).name:lower():find("cooldown") then
            for i=1,debug.getinfo(v).nups do
                local name=debug.getupvalue(v,i)
                if type(name)=="number" then debug.setupvalue(v,i,0) end
            end
        end
    end
end

function gainBall()
    local ball = getBall()
    if ball and getChar() then
        getChar():MoveTo(ball.Position + Vector3.new(0,1.5,0))
    end
end

function increaseHitbox()
    local c = getChar()
    if c then
        for _,v in pairs(c:GetDescendants()) do
            if v:IsA("BasePart") and v.Name~="HumanoidRootPart" then
                v.Size = v.Size + Vector3.new(2,2,2)
            end
        end
    end
end

function setBallSize()
    local b=getBall()
    if b then b.Size=Vector3.new(8,8,8) end
end

function rainbowify(obj)
    spawn(function()
        while hileVars.rainbowui and obj and obj:IsA("GuiObject") do
            for hue = 0, 255, 4 do
                if not hileVars.rainbowui or not obj.Parent then return end
                obj.BackgroundColor3 = Color3.fromHSV(hue/255, 0.6, 1)
                wait(0.01)
            end
        end
    end)
end

function wallPass()
    local c = getChar()
    if c then
        for _,v in pairs(c:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide=false end
        end
    end
end

function antiKick()
    if setreadonly and getrawmetatable then
        setreadonly(getrawmetatable(game),false)
        local mt=getrawmetatable(game)
        local old=mt.__namecall
        mt.__namecall=function(self,...)
            if getnamecallmethod and getnamecallmethod()=="Kick" then return end
            return old(self,...)
        end
        setreadonly(mt,true)
    end
end

