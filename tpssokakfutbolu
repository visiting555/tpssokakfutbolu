function getBall()
    local w=workspace
    return w:FindFirstChild("Ball") or (w.Balls and w.Balls:FindFirstChildWhichIsA("BasePart")) or nil
end

function setWalkSpeed(n)
    local c = getChar()
    if c and c:FindFirstChildOfClass("Humanoid") then
        c:FindFirstChildOfClass("Humanoid").WalkSpeed = n
    end
end

function setJumpPower(n)
    local c = getChar()
    if c and c:FindFirstChildOfClass("Humanoid") then
        c:FindFirstChildOfClass("Humanoid").JumpPower = n
    end
end

function infStamina()
    local p=getP()
    for _,v in pairs(workspace:GetDescendants()) do
        if v.Name:lower():find("stamina") and v:IsA("NumberValue") then
            v.Value=99999
        end
    end
end

function noCooldown()
    for _,v in pairs(getgc(true)) do
        if typeof(v)=="function" and islclosure(v) and debug.getinfo(v).name:lower():find("cooldown") then
            for i=1,debug.getinfo(v).nups do
                local name=debug.getupvalue(v,i)
                if type(name)=="number" then debug.setupvalue(v,i,0) end
            end
        end
    end
end

function gainBall()
    local ball = getBall()
    if ball and getChar() then
        local c = getChar()
        c:MoveTo(ball.Position + Vector3.new(0,1.5,0))
    end
end

function increaseHitbox()
    local c = getChar()
    if c then
        for _,v in pairs(c:GetDescendants()) do
            if v:IsA("BasePart") and v.Name~="HumanoidRootPart" then
                v.Size=v.Size+Vector3.new(2,2,2)
            end
        end
    end
end

function setBallSize()
    local b=getBall()
    if b then b.Size=Vector3.new(8,8,8) end
end

function rainbowify(obj)
    spawn(function()
        while hileVars.rainbowui do
            for hue = 0, 255, 4 do
                if obj.Parent==nil then return end
                obj.BackgroundColor3 = Color3.fromHSV(hue/255, 0.7, 1)
                wait(0.01)
            end
        end
    end)
end

function wallPass()
    local c = getChar()
    if c then
        for _,v in pairs(c:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide=false end
        end
    end
end

function antiKick()
    setreadonly(getrawmetatable(game),false)
    local mt=getrawmetatable(game)
    local old=mt.__namecall
    mt.__namecall=function(self,...)
        if getnamecallmethod()=="Kick" then return end
        return old(self,...)
    end
    setreadonly(mt,true)
end

function topEsp()
    local b = getBall()
    if b and not b:FindFirstChild("Bill") then
        local bb = Instance.new("BillboardGui",b)
        bb.Name = "Bill"
        bb.Adornee = b
        bb.Size = UDim2.new(0,90,0,30)
        bb.StudsOffset = Vector3.new(0,2.8,0)
        local lbl = Instance.new("TextLabel",bb)
        lbl.Text = "OYUN TOPU"
        lbl.Size = UDim2.new(1,0,1,0)
        lbl.BackgroundTransparency= 1
        lbl.TextColor3 = Color3.fromRGB(255,255,60)
        lbl.Font = Enum.Font.SourceSansBold
        lbl.TextScaled = true
    end
end

function chams(obj)
    if obj and obj:IsA("BasePart") then
        obj.Material = Enum.Material.ForceField
        obj.Color = Color3.fromRGB(90,10,255)
    end
end

function teamEsp()
    for _,p in pairs(game:GetService("Players"):GetPlayers()) do
        if p~=getP() and p.Team==getP().Team then
            local c=p.Character
            if c and c:FindFirstChild("Head") and not c.Head:FindFirstChild("ESP") then
                local b=Instance.new("BillboardGui",c.Head)
                b.Name="ESP"
                b.Size=UDim2.new(0,80,0,16)
                b.StudsOffset=Vector3.new(0,2,0)
                local t=Instance.new("TextLabel",b)
                t.Size=UDim2.new(1,0,1,0)
                t.BackgroundTransparency=1
                t.Text=p.Name
                t.TextColor3=Color3.fromRGB(25,255,50)
            end
        end
    end
end

function autoGoal()
    local c=getChar()
    if not c then return end
    local g=nil
    for _,v in pairs(workspace:GetChildren()) do
        if v.Name:lower():find("goal") or v.Name:lower():find("kale") then
            g=v
        end
    end
    if g then
        c:SetPrimaryPartCFrame(g.CFrame + Vector3.new(0,0,3))
    end
end

function autoDef()
    local c=getChar()
    if not c then return end
    for _,v in pairs(workspace:GetChildren()) do
        if v.Name:lower():find("defend") then
            c:SetPrimaryPartCFrame(v.CFrame+Vector3.new(0,0,1))
        end
    end
end

function autoGoalie()
    local c=getChar()
    if not c then return end
    for _,v in pairs(workspace:GetChildren()) do
        if v.Name:lower():find("goalie") or v.Name:lower():find("keeper") then
            c:SetPrimaryPartCFrame(v.CFrame+Vector3.new(0,0,2))
        end
    end
end

