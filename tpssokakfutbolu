local function slider(panel, y, title, min, max, default, callback)
    local lbl = Instance.new("TextLabel",panel)
    lbl.Size = UDim2.new(0.42,0,0,30)
    lbl.Position = UDim2.new(0.05,0,0,y)
    lbl.BackgroundTransparency = 1
    lbl.Text = title..": "..default
    lbl.Font = Enum.Font.Gotham
    lbl.TextColor3 = Color3.new(1,1,1)
    lbl.TextSize = 16

    local bar = Instance.new("Frame",panel)
    bar.Size = UDim2.new(0.42,0,0,10)
    bar.Position = UDim2.new(0.05,0,0,y+26)
    bar.BackgroundColor3 = Color3.fromRGB(70,70,70)
    bar.BorderSizePixel = 0
    bar.ZIndex = 15

    local handle = Instance.new("Frame",bar)
    handle.Size = UDim2.new(.13,0,1,0)
    handle.Position = UDim2.new(0,0,0,0)
    handle.BackgroundColor3 = Color3.fromRGB(240,181,36)
    handle.BorderSizePixel = 0
    handle.ZIndex=16

    local dragging = false

    handle.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging = true end
    end)
    handle.InputEnded:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    bar.InputChanged:Connect(function(input)
        if dragging and input.UserInputType==Enum.UserInputType.MouseMovement then
            local mx = input.Position.X-bar.AbsolutePosition.X
            local ratio = math.clamp(mx/bar.AbsoluteSize.X,0,1)
            handle.Position = UDim2.new(ratio,0,0,0)
            local val = math.floor(min+ratio*(max-min))
            lbl.Text = title..": "..val
            callback(val)
        end
    end)
end

