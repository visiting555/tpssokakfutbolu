RunService.RenderStepped:Connect(function()
    if not BRONXMENU.Enabled or not MainFrame or not MainFrame.Parent then return end

    local hum = getHum()
    if hum then
        hum.WalkSpeed = hileVars.walkspeed or 16
        hum.JumpPower = hileVars.jumppower or 50
    end

    if hileVars.gravity then
        Workspace.Gravity = 0.9
    else
        Workspace.Gravity = 196
    end

    if hileVars.noclip then
        local c = getChar()
        if c then
            for _,v in pairs(c:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end

    if hileVars.god and hum then
        hum.Health = hum.MaxHealth
        hum.BreakJointsOnDeath = false
    end

    if hileVars.infjump and not _G.BRONXINFJCONN then
        _G.BRONXINFJCONN = true
        UserInputService.JumpRequest:Connect(function()
            local h = getHum()
            if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
        end)
    end

    if hileVars.fastreload then
        for _,tool in pairs(getChar():GetChildren()) do
            if tool:FindFirstChild("ReloadTime") then tool.ReloadTime.Value = 0.01 end
        end
    end

    if hileVars.superJump and hum then
        hum.JumpPower = 150
    end

    if hileVars.superPunch then
        local c = getChar()
        if c then
            for _,v in pairs(c:GetDescendants()) do
                if v:IsA("Tool") and v.Name:lower():find("punch") then v:Activate() end
            end
        end
    end

    if hileVars.unlimitedAmmo then
        for _,tool in pairs(getChar():GetChildren()) do
            if tool:FindFirstChild("Ammo") then tool.Ammo.Value = 999 end
        end
    end

    if hileVars.infiniteMoney and ReplicatedStorage:FindFirstChild("Cash") then
        ReplicatedStorage.Cash.Value = 99999999
    end

    if hileVars.autoFarm then
        -- simplify, teleport between key locations or grab cash objects, this is example logic
        for _,v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") and v.Name == "MoneyBag" then
                if getRoot() then v.CFrame = getRoot().CFrame + Vector3.new(1,0,1) end
            end
        end
    end

    if hileVars.espPlayers then
        for _,p in pairs(Players:GetPlayers()) do
            if p ~= localPlayer and p.Character and p.Character:FindFirstChild("Head") then
                makeESP(p.Character.Head, p.DisplayName or p.Name)
            end
        end
    end

    if hileVars.moneyEsp then
        for _,v in pairs(Workspace:GetChildren()) do
            if v:IsA("BasePart") and v.Name:lower():find("money") then
                makeESP(v,"PARA")
            end
        end
    end

    if hileVars.rainbowui and MainFrame then
        local hsv = tick()%1
        MainFrame.BackgroundColor3 = Color3.fromHSV(hsv,0.6,0.4)
    else
        MainFrame.BackgroundColor3 = Color3.fromRGB(25,28,39)
    end

    if hileVars.tpspeedhack and getHum() then
        getHum().WalkSpeed = math.random(20,85)
    end

    if hileVars.xray then
        for _,v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") then v.LocalTransparencyModifier = 0.5 end
        end
    else
        for _,v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") then v.LocalTransparencyModifier = 0 end
        end
    end

    if hileVars.wallbang then
        for _,p in pairs(Players:GetPlayers()) do
            if p ~= localPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                p.Character.HumanoidRootPart.CanCollide = false
            end
        end
    end

    if hileVars.antikick and setreadonly and getrawmetatable then
        local mt = getrawmetatable(game)
        if mt and not mt.__Bronx__ then
            setreadonly(mt, false)
            mt.__Bronx__ = true
            local old = mt.__namecall
            mt.__namecall = function(self, ...)
                local method = getnamecallmethod and getnamecallmethod()
                if method == "Kick" then return end
                return old(self, ...)
            end
            setreadonly(mt, true)
        end
    end

    if hileVars.noDelay then
        for _,tool in pairs(getChar():GetChildren()) do
            if tool:FindFirstChild("FireRate") then tool.FireRate.Value = 0.02 end
        end
    end

    if hileVars.alwaysSprint and hum then
        hum.WalkSpeed = 55
    end

    if hileVars.jumpBoost and hum then
        hum.JumpPower = 180
    end

    if hileVars.flashaura and getRoot() then
        for _,v in pairs(Workspace:GetDescendants()) do
            if v:IsA("Part") and v.Name:lower():find("flashbang") then
                v.CFrame = getRoot().CFrame
            end
        end
    end

    if hileVars.nightVision and Lighting then
        Lighting.Brightness = 8
        Lighting.FogEnd = 1e5
        Lighting.ExposureCompensation = 2.2
        Lighting.Ambient = Color3.new(1,1,1)
    end

    if hileVars.aimlock and workspace.CurrentCamera and getRoot() then
        workspace.CurrentCamera.CameraSubject = getRoot()
        workspace.CurrentCamera.CameraType = Enum.CameraType.Attach
        workspace.CurrentCamera.FieldOfView = 90
    end

    if hileVars.hitbox then
        for _,p in pairs(Players:GetPlayers()) do
            if p ~= localPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                p.Character.HumanoidRootPart.Size = Vector3.new(12,12,12)
                p.Character.HumanoidRootPart.Transparency = 0.5
                p.Character.HumanoidRootPart.BrickColor = BrickColor.Yellow()
            end
        end
    end

    if hileVars.killAura then
        for _,p in pairs(Players:GetPlayers()) do
            if p ~= localPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and getRoot() then
                local dist = (getRoot().Position - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < 14 then
                    p.Character.Humanoid.Health = 0
                end
            end
        end
    end

    if hileVars.forceSit and getHum() then
        getHum().Sit = true
    end

    if hileVars.autoAraba and Workspace:FindFirstChild("Cars") then
        for _,v in pairs(Workspace.Cars:GetChildren()) do
            if v:IsA("Model") and v:FindFirstChild("DriveSeat") and getRoot() then
                getRoot().CFrame = v.DriveSeat.CFrame
            end
        end
    end

    if hileVars.teleport and getRoot() then
        getRoot().CFrame = CFrame.new(Vector3.new(320, 12, 142))
    end

    if hileVars.repaireverything and Workspace:FindFirstChild("RepairStation") then
        for _,v in pairs(Workspace.RepairStation:GetChildren()) do
            if v:IsA("BasePart") then v.BrickColor = BrickColor.Random() end
        end
    end
end)
       
