local function createToggle(tab,y,text,ref, key)
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0.46,0,0,39)
    toggle.Position = UDim2.new(#tab:GetChildren()%2==0 and 0.03 or 0.51,0,0,(y-1)*44+6)
    toggle.BackgroundColor3 = Color3.fromRGB(54,56,73)
    toggle.BorderSizePixel = 0
    toggle.TextColor3 = ref[key] and Color3.fromRGB(70,255,90) or Color3.fromRGB(160,170,220)
    toggle.Font = Enum.Font.GothamBold
    toggle.TextSize = 17
    toggle.Text = ("%s [%s]"):format(text,ref[key] and "AÇIK" or "KAPALI")
    toggle.Parent = tab
    toggle.MouseButton1Click:Connect(function()
        ref[key] = not ref[key]
        toggle.Text = ("%s [%s]"):format(text,ref[key] and "AÇIK" or "KAPALI")
        toggle.TextColor3 = ref[key] and Color3.fromRGB(70,255,90) or Color3.fromRGB(160,170,220)
        if key=="rainbowui" and ref[key] then
            spawn(function()
                while ref[key] and menu and menu.Parent do
                    for h=0,1,.02 do
                        menu.BackgroundColor3 = Color3.fromHSV(h,.37,.32)
                        wait(.03)
                        if not ref[key] then break end
                    end
                end
            end)
        end
    end)
end

