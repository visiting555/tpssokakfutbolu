    toggle.BorderSizePixel = 0
    toggle.MouseButton1Click:Connect(function()
        varTab[key] = not varTab[key]
        if varTab[key] then
            toggle.Text = baslik.." [AÇIK]"
            toggle.BackgroundColor3 = Color3.fromRGB(157,220,67)
            toggle.TextColor3 = Color3.fromRGB(40,40,40)
