local dragData = {dragging = false, dragInput = nil, start = nil, startPos = nil}
local function dragify(frame)
    frame.Active = true
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and not dragData.dragging then
            dragData.dragging = true
            dragData.start = Vector2.new(input.Position.X, input.Position.Y)
            dragData.startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragData.dragging = false
                end
            end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragData.dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragData.dragInput and dragData.dragging then
            local delta = Vector2.new(input.Position.X, input.Position.Y) - dragData.start
            frame.Position = UDim2.new(
                dragData.startPos.X.Scale, dragData.startPos.X.Offset + delta.X,
                dragData.startPos.Y.Scale, dragData.startPos.Y.Offset + delta.Y
            )
        end
    end)
end

